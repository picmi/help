{
  "name": "picmi-help",
  "version": "0.1.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "docs:build-index": "node ./node_modules/vetradocs-vitepress/bin/build-index.mjs --docs ./docs --output ./docs/public/search-index.json",
    "docs:dev": "yarn docs:build-index && vitepress dev docs",
    "docs:build": "yarn docs:build-index && vitepress build docs",
    "docs:serve": "vitepress serve docs"
  },
  "devDependencies": {
    "sass-embedded": "^1.79.5",
    "vitepress": "^1.3.4",
    "vitepress-tags": "^0.6.5",
    "vue": "^3.5.11"
  },
  "dependencies": {
    "markdown-it-container": "^4.0.0",
    "vetradocs-vitepress": "^1.0.4"
  }
}
