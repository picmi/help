{
  "name": "picmi-help",
  "version": "0.1.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "test": "vitest run",
    "docs:build-index": "node ./scripts/build-search-index.ts --docs ./docs --output ./docs/public/search-index.json",
    "docs:dev": "yarn docs:build-index && vitepress dev docs",
    "docs:build": "yarn docs:build-index && vitepress build docs",
    "docs:serve": "vitepress serve docs"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "sass-embedded": "^1.79.5",
    "typescript": "^6.0.3",
    "vitepress": "^1.3.4",
    "vitepress-tags": "^0.6.5",
    "vitest": "^2.1.9",
    "vue": "^3.5.11"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@orama/plugin-data-persistence": "^3.1.18",
    "markdown-it-container": "^4.0.0"
  }
}
